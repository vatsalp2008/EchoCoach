# ─────────────────────────────────────────────────────────────
# EchoCoach environment. Copy to .env and fill in secrets.
# Cognee reads these on `import cognee`, so .env must sit at the
# repo root (or the dir Python is launched from).
# ─────────────────────────────────────────────────────────────

# ── App LLM (grading + debrief), used by backend/app/llm_client.py ──
# Use a standard AI Studio API key (starts with "AIza"). Keys shaped "AQ.*" are
# quota-restricted (~20 requests/day) — avoid.
APP_LLM_PROVIDER=gemini
GEMINI_API_KEY=
APP_LLM_MODEL=gemini-2.5-flash

# ── Cognee internal LLM (cognify/recall/improve) — Gemini (see docs/DECISIONS ADR-011) ──
# Local Ollama models fail cognee's structured-output extraction and are minutes-slow,
# so graph-building runs on Gemini too. Uses a standard AIza key's free tier.
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash-lite
LLM_API_KEY=

# ── Cognee embeddings — local fastembed (in-process, no key, no Ollama) ──
# `pip install fastembed`. Cognee uses its default local model (BAAI/bge-small).
EMBEDDING_PROVIDER=fastembed

# ── Cognee local stack (defaults; stated explicitly for clarity) ──
VECTOR_DB_PROVIDER=lancedb
GRAPH_DATABASE_PROVIDER=kuzu
DB_PROVIDER=sqlite

# ── Phase 3: external grounding ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=echocoach:v1.0 (by /u/your_username)
GITHUB_TOKEN=

# ── Login PINs (2 known users, see backend/app/auth.py) ──
# Change these from the demo defaults if this ever leaves your machine.
PIN_VATSAL=1111
PIN_SAKSHI=2222
