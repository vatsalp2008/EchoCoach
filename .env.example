# ─────────────────────────────────────────────────────────────
# EchoCoach environment. Copy to .env and fill in secrets.
# Cognee reads these on `import cognee`, so .env must sit at the
# repo root (or the dir Python is launched from).
# ─────────────────────────────────────────────────────────────

# ── App LLM (grading + debrief), used by backend/app/llm_client.py ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=
APP_LLM_MODEL=gemini-2.5-flash

# ── Cognee internal LLM (cognify entity/relation extraction) ──
# Routed through LiteLLM ("gemini/" prefix required). Do NOT set LLM_ENDPOINT
# for gemini — LiteLLM routes natively and an override hangs the connection
# test (cognee issue #1530). Note: gemini-2.0-* models are quota-0 on the free
# tier; 2.5-flash-lite is the cheapest that works.
LLM_MODEL=gemini/gemini-2.5-flash-lite
LLM_API_KEY=

# ── Cognee embeddings ──
# gemini-embedding-001 (3072 dims) works on the free tier; text-embedding-004
# does not. If Gemini embeddings misbehave, switch EMBEDDING_PROVIDER=fastembed
# (local, free) and drop the model/key.
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_API_KEY=

# ── Cognee local stack (defaults; stated explicitly for clarity) ──
VECTOR_DB_PROVIDER=lancedb
GRAPH_DATABASE_PROVIDER=kuzu
DB_PROVIDER=sqlite

# ── Phase 3: external grounding ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=echocoach:v1.0 (by /u/your_username)
GITHUB_TOKEN=
